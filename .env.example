# ════════════════════════════════════════════════════
#  SPIDERGRAM v2 — Environment Variables
#  cp .env.example .env  →  fill every value
#  NEVER commit .env to git
# ════════════════════════════════════════════════════

# ── AI Models ────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3
GROK_API_KEY=your_grok_api_key

# ── News Sources ─────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key
GNEWS_API_KEY=your_gnews_api_key

# ── Media ─────────────────────────────────────────────
PEXELS_API_KEY=your_pexels_api_key

# ── Voice (TTS) ───────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Instagram ─────────────────────────────────────────
# Per-account tokens go in config/accounts.json
INSTAGRAM_APP_ID=your_app_id
INSTAGRAM_APP_SECRET=your_app_secret

# ── Telegram (Boss notifications) ────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── CDN ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud
CLOUDINARY_API_KEY=your_key
CLOUDINARY_API_SECRET=your_secret

# ── Web Dashboard ─────────────────────────────────────
FLASK_SECRET_KEY=change_this_random_string
DASHBOARD_PORT=7111

# ── Security ──────────────────────────────────────────
ENCRYPTION_KEY=generate_with_install.py
